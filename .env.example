AC_BASE_URL=http://example.local:8081
AC_USERNAME=your_username
AC_KEYCHAIN_SERVICE=company-ac
AC_PANEL_PORT=3033
AC_PANEL_TITLE=AC Control
AC_PANEL_UNIT_COLUMNS=VAV_01,VAV_03|VAV_02,VAV_04
AC_VERIFY_TIMEOUT_MS=60000
AC_VERIFY_INTERVAL_MS=3000

AC_MODE_ORD=station:|slot:/Drivers/NiagaraNetwork/DEVICE/points/MODE
AC_TEMP_ORD=station:|slot:/Drivers/NiagaraNetwork/DEVICE/points/TEMP_SETPOINT
AC_VAV_BASE_ORD=station:|slot:/Drivers/NiagaraNetwork/DEVICE/points
AC_VAVS=VAV_01,VAV_02

# Do not commit real passwords. macOS stores the password in Keychain.
# Windows scheduled tasks are non-interactive, so set AC_PASSWORD in the local ignored .env file.
# AC_PASSWORD=
